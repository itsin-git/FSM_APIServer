# -------------------------------------------------------
# FortiSIEM Database (PostgreSQL)
# -------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=phoenixdb
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=changeme
POSTGRES_MIN_POOL=2
POSTGRES_MAX_POOL=10
POSTGRES_SSL=false

# -------------------------------------------------------
# FortiSIEM Database (ClickHouse)
# -------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false

# -------------------------------------------------------
# Redis (Job Queue + Result Store)
# -------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_QUEUE_NAME=fsm_events
REDIS_RESULT_TTL=3600
REDIS_FAILURE_TTL=300

# -------------------------------------------------------
# Adapter server settings
# -------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

# -------------------------------------------------------
# API 인증 (이 서버로 들어오는 요청의 Basic Auth)
# FortiSIEM 형식: Authorization: Basic base64(<org>/<username>:<password>)
# 예) super/admin:password1234
# FortiSOAR connector의 organization/username/password와 동일하게 설정
# -------------------------------------------------------
API_ORG=super
API_USERNAME=admin
API_PASSWORD=changeme
